# Local AI Configuration - Replace OpenAI with Free Models
# Copy these variables to your .env file to enable local AI

# Primary AI Configuration
AI_PROVIDER=ollama
AI_BASE_URL=http://localhost:11434
AI_MODEL=llama3.2:3b
AI_MAX_TOKENS=2000
AI_TEMPERATURE=0.7

# Performance Settings
AI_TIMEOUT=30000
AI_RETRY_ATTEMPTS=3

# Fallback Configuration (Optional)
AI_FALLBACK_OPENAI=true
# OPENAI_API_KEY=your_openai_key_for_fallback_only

# Alternative Providers (Choose one)
# For LM Studio:
# AI_PROVIDER=lmstudio
# AI_BASE_URL=http://localhost:1234
# AI_MODEL=your-local-model

# For Hugging Face Inference API:
# AI_PROVIDER=huggingface
# AI_MODEL=meta-llama/Llama-2-7b-chat-hf
# AI_API_KEY=your_huggingface_token

# Redis Caching (Optional but recommended)
REDIS_URL=redis://localhost:6379